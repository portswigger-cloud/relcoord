# Example relcoord configuration.

host = "0.0.0.0"
port = 8080
log-level = "INFO"
manifests-repository = "https://github.com/example/manifests.git"
detect-deployment = false

[persistence]
backend = "surrealdb"
uri = "ws://localhost:8000"
namespace = "default"
database = "relcoord"

[persistence.idmouse]
url = "http://localhost:9000/token/relcoord"
token-path = "/tmp/idmouse-bearer-token"

# Alternative DynamoDB persistence backend. The table needs string keys pk and sk.
#
# [persistence]
# backend = "dynamodb"
# table-name = "relcoord-image-versions"
# region-name = "eu-west-2"
# endpoint-url = "http://localhost:8000"

[idcat]
endpoint = "https://idcat.example.com"
github-app = "deployments"
token-path = "/tmp/idcat-bearer-token"

# Bearer-token authentication for write endpoints. Each [[role]] entry
# describes one acceptable JWT issuer. A request to /v1/image-versions or
# /v1/change must present a Bearer token that validates against at least one
# role. Read endpoints (/healthz, /v1/images/latest) are not authenticated.

[[role]]
name = "kubernetes-default"
audience = "relcoord"
issuer = "https://kubernetes.default.svc"
jwks-uri = "https://kubernetes.default.svc/openid/v1/jwks"

[role.claims]
sub = "system:serviceaccount:default:default"
