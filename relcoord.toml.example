# Example relcoord configuration.

listen = "0.0.0.0"
port = 8080
log-level = "INFO"
detect-deployment = false

[[output]]
name = "example-dev"
repository = "https://github.com/example/manifests"
directory = "example-dev"

[output.vars]
cluster_name = "example-dev"
account_id = 111122223333
issuer = "https://oidc.eks.eu-west-1.amazonaws.com/id/EXAMPLEDEVCLUSTERID"

[[output]]
name = "example-prod"
repository = "https://github.com/example/manifests"
directory = "example-prod"

[output.vars]
cluster_name = "example-prod"
account_id = 444455556666
issuer = "https://oidc.eks.eu-west-1.amazonaws.com/id/EXAMPLEPRODCLUSTERID"

[persistence]
backend = "surrealdb"
uri = "ws://localhost:8000"
namespace = "default"
database = "relcoord"

[persistence.idmouse]
url = "http://localhost:9000/token/relcoord"
token-path = "/tmp/idmouse-bearer-token"

# Alternative DynamoDB persistence backend. The table needs string keys pk and sk.
#
# [persistence]
# backend = "dynamodb"
# table-name = "relcoord-image-versions"
# region-name = "eu-west-2"
# endpoint-url = "http://localhost:8000"

[idcat]
endpoint = "https://idcat.example.com"
github-app = "deployments"
token-path = "/tmp/idcat-bearer-token"

# Bearer-token authentication for write endpoints. Each [[role]] entry
# describes one acceptable JWT issuer. A request to /v1/image-versions or
# /v1/change must present a Bearer token that validates against at least one
# role. Read endpoints (/healthz, /v1/images/latest) are not authenticated.

[[role]]
name = "kubernetes-default"
audience = "relcoord"
issuer = "https://kubernetes.default.svc"
jwks-uri = "https://kubernetes.default.svc/openid/v1/jwks"

# Set allow_system = true to permit this role to make system-mode change
# requests (payloads with "system": true), which read config from the
# repository root and generate manifests as the 'system' owner across all
# namespaces and cluster-scoped directories. Defaults to false.
allow_system = false

[role.claims]
sub = "system:serviceaccount:default:default"
